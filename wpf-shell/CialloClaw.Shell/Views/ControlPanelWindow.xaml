<Window x:Class="CialloClaw.Shell.Views.ControlPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CialloClaw 控制面板"
        Width="1240"
        Height="840"
        MinWidth="980"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#FFF8F1E5">
    <Window.Resources>
        <LinearGradientBrush x:Key="PanelHeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFAF2" Offset="0" />
            <GradientStop Color="#FFF7E8CF" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFCF7" Offset="0" />
            <GradientStop Color="#FFF8EEDD" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="PanelCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="#FFFFFCF5" />
            <Setter Property="BorderBrush" Value="#E7C583" />
        </Style>

        <Style x:Key="PanelTabItemStyle" TargetType="TabItem">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Foreground" Value="#8E1E2C" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Background="#FFF8ECD2"
                                BorderBrush="#E3BD79"
                                BorderThickness="1.1"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFFF8EE" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C98F4B" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFFF3DF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#7D2233" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFCF7" />
            <Setter Property="BorderBrush" Value="#E7C583" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="#FFFFFBF3" />
            <Setter Property="AlternatingRowBackground" Value="#FFFDF1DD" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#F2DFC0" />
            <Setter Property="VerticalGridLinesBrush" Value="#F2DFC0" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF6E7CB" />
            <Setter Property="Foreground" Value="#7A2533" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="320" Height="320" Fill="#22F6D89C" Canvas.Left="-90" Canvas.Top="-70" />
            <Ellipse Width="260" Height="260" Fill="#1ED9B5B6" Canvas.Right="80" Canvas.Top="90" />
            <Ellipse Width="340" Height="340" Fill="#18E7B8C7" Canvas.Right="-120" Canvas.Bottom="-120" />
        </Canvas>

        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="30"
                    Padding="22"
                    Background="{StaticResource PanelHeroBrush}"
                    BorderBrush="#E6C17B"
                    BorderThickness="1.3">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="26" ShadowDepth="5" Color="#3A2D1E" Opacity="0.12" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <WrapPanel>
                            <Border Padding="10,4" CornerRadius="10" Margin="0,0,10,0" Background="#FFF9E7C9" BorderBrush="#E1B96F" BorderThickness="1">
                                <TextBlock Text="东方灵感" FontWeight="Bold" Foreground="#7D2333" />
                            </Border>
                            <Border Padding="10,4" CornerRadius="10" Margin="0,0,10,0" Background="#FFF5ECD9" BorderBrush="#E1C28B" BorderThickness="1">
                                <TextBlock Text="本地模拟" FontWeight="Bold" Foreground="#6E4A2E" />
                            </Border>
                            <Border Padding="10,4" CornerRadius="10" Background="#FFF6EEDA" BorderBrush="#D5C090" BorderThickness="1">
                                <TextBlock Text="桌面常驻" FontWeight="Bold" Foreground="#6E4A2E" />
                            </Border>
                        </WrapPanel>

                        <TextBlock Margin="0,14,0,0"
                                   Text="控制面板 / 全景仪表盘"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="#8E1E2C" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="像符卡目录一样整理助手的状态、权限、任务环、巡检与技能。首页先看全景，再进入低频设置。"
                                   FontSize="15"
                                   Foreground="#755942"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <ComboBox Width="220"
                                  Margin="0,0,10,0"
                                  ItemsSource="{Binding Agents}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding SelectedAgent}" />
                        <Button Width="96" Height="40" Content="关闭" Click="CloseButton_OnClick" />
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Grid.ColumnSpan="2" Columns="4" Margin="0,20,0,0">
                        <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,12,0" Background="#FFFFF7EA">
                            <StackPanel>
                                <TextBlock Text="时间线" Foreground="#7A5C3D" />
                                <TextBlock Text="{Binding Timeline.Count}" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Text="最近发生的关键动作" Foreground="#9A8060" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,12,0" Background="#FFFFF7EA">
                            <StackPanel>
                                <TextBlock Text="工具调用" Foreground="#7A5C3D" />
                                <TextBlock Text="{Binding ToolCalls.Count}" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Text="外部执行轨迹" Foreground="#9A8060" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource PanelCardStyle}" Margin="0,0,12,0" Background="#FFFFF7EA">
                            <StackPanel>
                                <TextBlock Text="任务巡检" Foreground="#7A5C3D" />
                                <TextBlock Text="{Binding NoteTasks.Count}" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Text="便签与待办状态" Foreground="#9A8060" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource PanelCardStyle}" Margin="0" Background="#FFFFF7EA">
                            <StackPanel>
                                <TextBlock Text="任务环" Foreground="#7A5C3D" />
                                <TextBlock Text="{Binding EnabledRingTasks.Count}" Style="{StaticResource MetricValueStyle}" />
                                <TextBlock Text="只在你添加后才显示" Foreground="#9A8060" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,16,0,0"
                    CornerRadius="28"
                    Background="{StaticResource PanelShellBrush}"
                    BorderBrush="#E8C989"
                    BorderThickness="1.15"
                    Padding="16">
                <TabControl x:Name="MainTabControl"
                            Grid.Row="1"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemContainerStyle="{StaticResource PanelTabItemStyle}">
            <TabItem Header="首页仪表盘">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="260" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,0,12" Background="#FFF9EDD7">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="全景操作仪表盘" FontSize="20" FontWeight="Bold" Foreground="#8E1E2C" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="这里承接桌面入口之外的低频信息：时间线、证据、巡检和多技能状态。"
                                           Foreground="#7A5C3D"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="12,6"
                                    CornerRadius="12"
                                    Background="#FFFDF4E4"
                                    BorderBrush="#E0B971"
                                    BorderThickness="1">
                                <TextBlock Text="事件驱动 / SSE 模拟"
                                           FontWeight="Bold"
                                           Foreground="#7A2533" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,8,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="时间线" FontWeight="Bold" FontSize="15" Margin="0,0,0,8" Foreground="#8E1E2C" />
                                <ListBox ItemsSource="{Binding Timeline}" BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Detail}" Foreground="#5F4E3C" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding TimestampText}" FontSize="10" Foreground="#9E8B74" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}" Margin="4,0,4,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="工具调用" FontWeight="Bold" FontSize="15" Margin="0,0,0,8" Foreground="#8E1E2C" />
                                <ListBox ItemsSource="{Binding ToolCalls}" BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding ArgsText}" Foreground="#5F4E3C" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Status, StringFormat=状态: {0}}" FontSize="10" Foreground="#9E8B74" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}" Margin="8,0,0,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="证据 / 引用" FontWeight="Bold" FontSize="15" Margin="0,0,0,8" Foreground="#8E1E2C" />
                                <ListBox ItemsSource="{Binding Citations}" BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Source}" FontSize="10" Foreground="#9E8B74" />
                                                <TextBlock Text="{Binding Snippet}" Foreground="#5F4E3C" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,8,8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="一、浏览器流" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="#8E1E2C" />
                                <ListBox ItemsSource="{Binding BrowserFeed}" BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4">
                                                <TextBlock Text="{Binding Primary}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Detail}" Foreground="#5F4E3C" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding TimestampText}" FontSize="10" Foreground="#9E8B74" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelCardStyle}" Margin="8,0,0,8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="二、终端流" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="#8E1E2C" />
                                <ListBox ItemsSource="{Binding TerminalFeed}" BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4">
                                                <TextBlock Text="{Binding Primary}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Detail}" Foreground="#5F4E3C" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding TimestampText}" FontSize="10" Foreground="#9E8B74" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelCardStyle}" Margin="0,8,8,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="三、文件流" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="#8E1E2C" />
                                <ListBox ItemsSource="{Binding FileFeed}" BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4">
                                                <TextBlock Text="{Binding Primary}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Detail}" Foreground="#5F4E3C" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding TimestampText}" FontSize="10" Foreground="#9E8B74" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelCardStyle}" Margin="8,8,0,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="四、决策流" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="#8E1E2C" />
                                <ListBox ItemsSource="{Binding DecisionFeed}" BorderThickness="0" Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4">
                                                <TextBlock Text="{Binding Primary}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Detail}" Foreground="#5F4E3C" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding TimestampText}" FontSize="10" Foreground="#9E8B74" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="通用">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="语言与常驻" FontWeight="Bold" FontSize="18" Foreground="#8E1E2C" />
                        <WrapPanel Margin="0,8,0,8">
                            <TextBlock Text="界面语言：" VerticalAlignment="Center" />
                            <ComboBox Width="160"
                                      Margin="6,0,16,0"
                                      SelectedValue="{Binding Settings.Language}"
                                      SelectedValuePath="Tag">
                                <ComboBoxItem Content="简体中文" Tag="zh-CN" />
                                <ComboBoxItem Content="繁體中文" Tag="zh-TW" />
                            </ComboBox>
                            <CheckBox Content="开机自启" Margin="0,0,16,0" IsChecked="{Binding Settings.AutoStart}" />
                            <CheckBox Content="最小化到托盘" Margin="0,0,16,0" IsChecked="{Binding Settings.MinimizeToTray}" />
                            <CheckBox Content="关闭窗口保留后台" IsChecked="{Binding Settings.KeepRunningOnClose}" />
                        </WrapPanel>

                        <Separator Margin="0,8,0,8" />

                        <TextBlock Text="通知" FontWeight="Bold" FontSize="16" Foreground="#8E1E2C" />
                        <WrapPanel Margin="0,8,0,8">
                            <CheckBox Content="系统通知" Margin="0,0,18,0" IsChecked="{Binding Settings.SystemNotifyEnabled}" />
                            <CheckBox Content="声音提醒" IsChecked="{Binding Settings.SoundReminderEnabled}" />
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="外观与桌面入口">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <WrapPanel Margin="0,0,0,10">
                            <CheckBox Content="显示悬浮球" Margin="0,0,18,0" IsChecked="{Binding Settings.ShowFloatingBall}" />
                            <CheckBox Content="自动贴边" Margin="0,0,18,0" IsChecked="{Binding Settings.AutoDock}" />
                            <CheckBox Content="空闲半透明" Margin="0,0,18,0" IsChecked="{Binding Settings.IdleHalfTransparent}" />
                            <CheckBox Content="启用任务环" IsChecked="{Binding Settings.EnableTaskRing}" />
                        </WrapPanel>
                        <TextBlock Text="悬浮球尺寸" />
                        <Slider Minimum="72" Maximum="152" Value="{Binding Settings.BallSize}" Width="320" Margin="0,6,0,8" />
                        <TextBlock Text="任务环只在你手动添加任务球后出现；不添加就不会显示任何额外球。" Foreground="#6A4E2A" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="可添加任务球" FontWeight="Bold" Margin="0,0,0,8" Foreground="#8E1E2C" />
                                <ListBox ItemsSource="{Binding AvailableRingTasks}"
                                         SelectedItem="{Binding SelectedAvailableRingTask}"
                                         DisplayMemberPath="DisplayLabel" />
                            </DockPanel>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12">
                            <Button Width="82" Height="34" Content="添加 →" Command="{Binding AddRingTaskCommand}" Margin="0,0,0,8" />
                            <Button Width="82" Height="34" Content="← 移除" Command="{Binding RemoveRingTaskCommand}" Margin="0,0,0,8" />
                            <Button Width="82" Height="34" Content="清空" Command="{Binding ClearRingTasksCommand}" />
                        </StackPanel>

                        <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="已启用任务球" FontWeight="Bold" Margin="0,0,0,8" Foreground="#8E1E2C" />
                                <ListBox ItemsSource="{Binding EnabledRingTasks}"
                                         SelectedItem="{Binding SelectedEnabledRingTask}"
                                         DisplayMemberPath="DisplayLabel" />
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="主动协助">
                <StackPanel Margin="12">
                    <WrapPanel Margin="0,0,0,10">
                        <CheckBox Content="启用主动协助" Margin="0,0,18,0" IsChecked="{Binding Settings.ActiveAssistEnabled}" />
                        <CheckBox Content="仅明确场景触发" Margin="0,0,18,0" IsChecked="{Binding Settings.ProactiveOnlySafeMode}" />
                    </WrapPanel>

                    <WrapPanel Margin="0,0,0,10">
                        <TextBlock Text="默认提醒等级：" VerticalAlignment="Center" />
                        <ComboBox Width="140" Margin="6,0,20,0" SelectedValue="{Binding Settings.AssistLevelDefault}" SelectedValuePath="Tag">
                            <ComboBoxItem Content="L0（静默）" Tag="0" />
                            <ComboBoxItem Content="L1（轻提醒）" Tag="1" />
                            <ComboBoxItem Content="L2（普通）" Tag="2" />
                            <ComboBoxItem Content="L3（高优先）" Tag="3" />
                            <ComboBoxItem Content="L4（强提醒）" Tag="4" />
                        </ComboBox>

                        <TextBlock Text="全局最小间隔（秒）：" VerticalAlignment="Center" />
                        <TextBox Width="60" Margin="6,0,20,0" Text="{Binding Settings.NudgeMinIntervalSec}" />

                        <TextBlock Text="每小时上限：" VerticalAlignment="Center" />
                        <TextBox Width="60" Margin="6,0,0,0" Text="{Binding Settings.NudgeMaxPerHour}" />
                    </WrapPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="执行与安全">
                <StackPanel Margin="12">
                    <TextBlock Text="权限分级（当前助手）" FontWeight="Bold" FontSize="15" Foreground="#8E1E2C" />
                    <TextBlock Text="绿灯动作" Margin="0,8,0,4" FontWeight="Bold" />
                    <TextBlock Text="{Binding GreenActionsText}" TextWrapping="Wrap" />

                    <TextBlock Text="黄灯动作" Margin="0,8,0,4" FontWeight="Bold" />
                    <TextBlock Text="{Binding YellowActionsText}" TextWrapping="Wrap" />

                    <TextBlock Text="红灯动作" Margin="0,8,0,4" FontWeight="Bold" />
                    <TextBlock Text="{Binding RedActionsText}" TextWrapping="Wrap" />
                </StackPanel>
            </TabItem>

            <TabItem Header="任务巡检">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelCardStyle}" Padding="10">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="任务便签巡检" FontWeight="Bold" FontSize="15" Foreground="#8E1E2C" />
                                <TextBlock Text="{Binding InspectInfo}" Margin="0,2,0,0" Foreground="#6A4E2A" />
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Width="120" Height="32" Content="立即巡检" Command="{Binding InspectTasksCommand}" />
                        </DockPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              Margin="0,10,0,0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              ItemsSource="{Binding NoteTasks}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="任务" Binding="{Binding Title}" Width="2*" />
                            <DataGridTextColumn Header="状态" Binding="{Binding DisplayStatus}" Width="*" />
                            <DataGridTextColumn Header="优先级" Binding="{Binding Priority}" Width="*" />
                            <DataGridTextColumn Header="截止" Binding="{Binding DueText}" Width="*" />
                            <DataGridTextColumn Header="标签" Binding="{Binding TagsText}" Width="*" />
                            <DataGridTextColumn Header="建议" Binding="{Binding SuggestedNext}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="插件 / 技能">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelCardStyle}" Padding="10">
                        <StackPanel>
                            <TextBlock Text="多生态插件兼容层" FontWeight="Bold" FontSize="15" Foreground="#8E1E2C" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="支持内建技能与 GitHub 技能来源标识，后续可接真实安装与权限审计。"
                                       Foreground="#6A4E2A"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              Margin="0,10,0,0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              ItemsSource="{Binding Skills}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="90" />
                            <DataGridTextColumn Header="来源" Binding="{Binding DisplaySource}" Width="120" />
                            <DataGridCheckBoxColumn Header="已安装" Binding="{Binding Installed}" Width="90" />
                            <DataGridTextColumn Header="作用域" Binding="{Binding DisplayScope}" Width="140" />
                            <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
            </Border>
        </Grid>
    </Grid>
</Window>
