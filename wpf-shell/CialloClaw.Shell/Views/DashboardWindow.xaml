<Window x:Class="CialloClaw.Shell.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CialloClaw 全景操作仪表盘"
        Width="1180"
        Height="780"
        MinWidth="980"
        MinHeight="680">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="270" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="时间线" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding Timeline}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Detail}" Foreground="#5A7288" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding TimestampText}" FontSize="10" Foreground="#8FA4B7" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="4,0,4,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="工具调用" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding ToolCalls}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ArgsText}" Foreground="#5A7288" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Status, StringFormat=状态: {0}}" FontSize="10" Foreground="#8FA4B7" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="8,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="证据 / 引用" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding Citations}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Source}" FontSize="10" Foreground="#8FA4B7" />
                                    <TextBlock Text="{Binding Snippet}" Foreground="#5A7288" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,8,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="A. 浏览器流" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding BrowserFeed}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Primary}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Detail}" Foreground="#5A7288" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding TimestampText}" FontSize="10" Foreground="#8FA4B7" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="8,0,0,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="B. 终端流" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding TerminalFeed}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Primary}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Detail}" Foreground="#5A7288" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding TimestampText}" FontSize="10" Foreground="#8FA4B7" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,8,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="C. 文件流" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding FileFeed}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Primary}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Detail}" Foreground="#5A7288" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding TimestampText}" FontSize="10" Foreground="#8FA4B7" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="8,8,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="D. 决策流" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding DecisionFeed}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Primary}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Detail}" Foreground="#5A7288" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding TimestampText}" FontSize="10" Foreground="#8FA4B7" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
