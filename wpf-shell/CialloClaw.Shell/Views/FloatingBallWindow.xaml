<Window x:Class="CialloClaw.Shell.Views.FloatingBallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CialloClaw"
        Width="260"
        Height="260"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    <Window.Resources>
        <LinearGradientBrush x:Key="DockShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFAF1" Offset="0" />
            <GradientStop Color="#FFFCECD6" Offset="0.56" />
            <GradientStop Color="#FFF7E1CB" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DockFeatureBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFF8EB" Offset="0" />
            <GradientStop Color="#FFFBE5D0" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DockVoiceBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFF0D7" Offset="0" />
            <GradientStop Color="#FFF2C989" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="DockActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="BorderBrush" Value="#D8AA67" />
            <Setter Property="Background" Value="#FFFDF1D9" />
            <Setter Property="Foreground" Value="#7A2731" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFFFF7E8" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFF3D8AE" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DockChipButtonStyle" TargetType="Button" BasedOn="{StaticResource DockActionButtonStyle}">
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#FFFFF7E7" />
        </Style>

        <Style x:Key="DockVoiceButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="94" />
            <Setter Property="Height" Value="94" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="OuterRing"
                                     Fill="{StaticResource DockVoiceBrush}"
                                     Stroke="#D7A15C"
                                     StrokeThickness="2.2" />
                            <Ellipse x:Name="InnerGlow"
                                     Margin="10"
                                     Fill="#FFFFFBF3"
                                     Opacity="0.65" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterRing" Property="Fill" Value="#FFFFE1B7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="OuterRing" Property="Fill" Value="#FFF0C57C" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                <Setter TargetName="OuterRing" Property="Fill" Value="#FFF7C8CF" />
                                <Setter TargetName="OuterRing" Property="Stroke" Value="#C85366" />
                                <Setter TargetName="InnerGlow" Property="Fill" Value="#FFFFF5F6" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OuterRing" Property="Fill" Value="#FFE7D7B8" />
                                <Setter TargetName="OuterRing" Property="Stroke" Value="#C8B79B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" MouseEnter="RootGrid_OnMouseEnter" MouseLeave="RootGrid_OnMouseLeave">
        <ItemsControl x:Name="TaskRingItems"
                      Visibility="{Binding IsRingVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                      ItemsSource="{Binding RadialTasks}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas Width="260" Height="260" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Width="42"
                            Height="42"
                            FontSize="11"
                            FontWeight="Bold"
                            ToolTip="{Binding Task.DisplayDescription}"
                            BorderBrush="#E6BC72"
                            Background="#FFF6EECF"
                            Command="{Binding DataContext.QuickTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding Task}">
                        <TextBlock Text="{Binding Task.DisplayShortLabel}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#8E1E2C" />
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Popup x:Name="CompanionPopup"
               Placement="Custom"
               PlacementTarget="{Binding ElementName=BallHitArea}"
               CustomPopupPlacementCallback="CompanionPopup_CustomPopupPlacement"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               StaysOpen="True">
            <Border x:Name="CompanionHost"
                    Width="404"
                    Padding="16"
                    Background="Transparent"
                    MouseEnter="CompanionHost_OnMouseEnter"
                    MouseLeave="CompanionHost_OnMouseLeave">
                <Border CornerRadius="24"
                        Padding="18"
                        Background="{StaticResource DockShellBrush}"
                        BorderBrush="#E4BC79"
                        BorderThickness="1.4">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28" ShadowDepth="6" Color="#66311922" Opacity="0.55" />
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="桌面伴随台"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#8E1E2C" />
                                <TextBlock Text="{Binding StatusText, StringFormat=当前状态：{0}}"
                                           Margin="0,4,0,0"
                                           Foreground="#84684A" />
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Top">
                                <ComboBox Width="118"
                                          Margin="0,0,8,0"
                                          ItemsSource="{Binding Agents}"
                                          DisplayMemberPath="DisplayName"
                                          SelectedItem="{Binding SelectedAgent}" />
                                <Button Width="84"
                                        Content="展开舞台"
                                        Style="{StaticResource DockActionButtonStyle}"
                                        Click="OpenStageButton_OnClick" />
                            </StackPanel>
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="0,16,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="118" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="0,0,14,12"
                                    Padding="14"
                                    CornerRadius="18"
                                    Background="{StaticResource DockFeatureBrush}"
                                    BorderBrush="#E7C586"
                                    BorderThickness="1.1">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="{Binding FeaturedTitle}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#8E1E2C" />
                                        <Border DockPanel.Dock="Right"
                                                Padding="8,3"
                                                CornerRadius="9"
                                                Background="#FFFDF0D8"
                                                BorderBrush="#E1B76C"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding FeaturedRoleLabel}"
                                                       FontWeight="Bold"
                                                       Foreground="#7B2532" />
                                        </Border>
                                    </DockPanel>
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding FeaturedContent}"
                                               TextWrapping="Wrap"
                                               LineHeight="26"
                                               FontSize="15"
                                               Foreground="#47301F" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding FeaturedMeta}"
                                               Foreground="#8A6B48" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,0,14,0"
                                    Padding="14"
                                    CornerRadius="18"
                                    Background="#FFFFFBF3"
                                    BorderBrush="#E7C586"
                                    BorderThickness="1.1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel>
                                        <TextBlock Text="轻声纸签"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="#8E1E2C" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Width="160"
                                                   TextAlignment="Right"
                                                   Text="{Binding VoiceDraftText, StringFormat=最近识别：{0}}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#8A6A47">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding VoiceDraftText}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DockPanel>

                                    <Grid Grid.Row="1" Margin="0,10,0,0">
                                        <TextBox x:Name="CompanionInputBox"
                                                 MinHeight="72"
                                                 MaxHeight="112"
                                                 Padding="12,10"
                                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 KeyDown="CompanionInputBox_OnKeyDown" />
                                        <TextBlock Margin="14,12,88,0"
                                                   VerticalAlignment="Top"
                                                   Foreground="#A89375"
                                                   Text="在桌面上直接说一句需求，比如：帮我整理今天要做的三件事。"
                                                   TextWrapping="Wrap"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding InputText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <DockPanel Grid.Row="2" Margin="0,12,0,0">
                                        <TextBlock Text="{Binding ComposerStateText}"
                                                   VerticalAlignment="Center"
                                                   Foreground="#836542" />
                                        <Button DockPanel.Dock="Right"
                                                Width="92"
                                                Height="36"
                                                Content="发起本轮"
                                                Style="{StaticResource DockActionButtonStyle}"
                                                IsEnabled="{Binding IsSendEnabled}"
                                                Command="{Binding SendCommand}" />
                                    </DockPanel>
                                </Grid>
                            </Border>

                            <Border Grid.RowSpan="2"
                                    Grid.Column="1"
                                    Padding="12"
                                    CornerRadius="20"
                                    Background="#FFFFFBF4"
                                    BorderBrush="#E6C17C"
                                    BorderThickness="1.1">
                                <StackPanel>
                                    <Button Style="{StaticResource DockVoiceButtonStyle}"
                                            HorizontalAlignment="Center"
                                            Tag="{Binding IsListening}"
                                            Command="{Binding ToggleVoiceCommand}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding VoiceOrbText}"
                                                       HorizontalAlignment="Center"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="#7B2333" />
                                            <TextBlock Text="语音"
                                                       HorizontalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="#7A5B3B" />
                                        </StackPanel>
                                    </Button>

                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding VoiceStatusText}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Foreground="#7A5B3B" />

                                    <CheckBox Margin="0,12,0,0"
                                              Content="识别后自动发送"
                                              IsChecked="{Binding VoiceAutoSendEnabled}" />
                                    <CheckBox Margin="0,6,0,0"
                                              Content="助手自动朗读"
                                              IsChecked="{Binding AutoSpeakEnabled}" />

                                    <Button Margin="0,12,0,8"
                                            Content="朗读当前"
                                            Style="{StaticResource DockActionButtonStyle}"
                                            Command="{Binding SpeakLatestCommand}" />
                                    <Button Content="停止朗读"
                                            Style="{StaticResource DockActionButtonStyle}"
                                            Command="{Binding StopSpeakingCommand}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <WrapPanel Grid.Row="2">
                            <Button Style="{StaticResource DockChipButtonStyle}"
                                    Content="总结一下"
                                    Tag="请帮我总结当前内容"
                                    Click="QuickChip_OnClick" />
                            <Button Style="{StaticResource DockChipButtonStyle}"
                                    Content="翻成中文"
                                    Tag="请帮我翻译成中文并保留原意"
                                    Click="QuickChip_OnClick" />
                            <Button Style="{StaticResource DockChipButtonStyle}"
                                    Content="整理待办"
                                    Tag="请把这件事整理成可执行待办"
                                    Click="QuickChip_OnClick" />
                            <Button Style="{StaticResource DockChipButtonStyle}"
                                    Content="下一步做什么"
                                    Tag="请给出当前场景最合理的下一步"
                                    Click="QuickChip_OnClick" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </Border>
        </Popup>

        <Border x:Name="BallHitArea"
                Width="116"
                Height="116"
                Background="#01000000"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Cursor="Hand"
                MouseLeftButtonDown="BallHitArea_OnMouseLeftButtonDown"
                MouseLeftButtonUp="BallHitArea_OnMouseLeftButtonUp"
                MouseMove="BallHitArea_OnMouseMove"
                MouseEnter="BallHitArea_OnMouseEnter"
                MouseLeave="BallHitArea_OnMouseLeave">
            <Border.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="打开会话舞台" Command="{Binding OpenChatCommand}" />
                    <MenuItem Header="暂停/恢复助手" Command="{Binding TogglePauseCommand}" />
                    <Separator />
                    <MenuItem Header="打开控制面板（首页仪表盘）" Command="{Binding OpenControlPanelCommand}" />
                    <Separator />
                    <MenuItem Header="退出程序" Command="{Binding ExitCommand}" />
                </ContextMenu>
            </Border.ContextMenu>

            <Grid Width="104" Height="104" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding AvatarScale}" ScaleY="{Binding AvatarScale}" />
                        <RotateTransform Angle="{Binding AvatarRotation}" />
                        <TranslateTransform Y="{Binding AvatarOffsetY}" />
                    </TransformGroup>
                </Grid.RenderTransform>
                <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>

                <Viewbox Width="104"
                         Height="104"
                         Stretch="Uniform"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         IsHitTestVisible="False">
                    <Canvas Width="{Binding SourceCanvasWidthValue}"
                            Height="{Binding SourceCanvasHeightValue}"
                            Opacity="{Binding BallOpacity}"
                            SnapsToDevicePixels="True">
                        <Canvas.Effect>
                            <DropShadowEffect BlurRadius="20" Color="#90351A2A" ShadowDepth="4" Opacity="0.65" />
                        </Canvas.Effect>

                        <Image Source="{Binding HairLeftLayerPath, Converter={StaticResource AssetPathToImageConverter}}"
                               Canvas.Left="{Binding LeftTailX}"
                               Canvas.Top="{Binding LeftTailY}"
                               Opacity="{Binding TailHairOpacity}"
                               RenderOptions.BitmapScalingMode="NearestNeighbor" />

                        <Image Source="{Binding HairRightLayerPath, Converter={StaticResource AssetPathToImageConverter}}"
                               Canvas.Left="{Binding RightTailX}"
                               Canvas.Top="{Binding RightTailY}"
                               Opacity="{Binding TailHairOpacity}"
                               RenderOptions.BitmapScalingMode="NearestNeighbor" />

                        <Image Source="{Binding AvatarBaseLayerPath, Converter={StaticResource AssetPathToImageConverter}}"
                               Canvas.Left="0"
                               Canvas.Top="0"
                               RenderOptions.BitmapScalingMode="NearestNeighbor" />

                        <Image Source="{Binding HairFrontLayerPath, Converter={StaticResource AssetPathToImageConverter}}"
                               Canvas.Left="{Binding FrontHairX}"
                               Canvas.Top="{Binding FrontHairY}"
                               Opacity="{Binding FrontHairOpacity}"
                               RenderOptions.BitmapScalingMode="NearestNeighbor" />

                        <Canvas Visibility="{Binding ShowEyeOverlay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Rectangle Width="7"
                                       Height="7"
                                       Fill="#22080D"
                                       Canvas.Left="{Binding LeftPupilX}"
                                       Canvas.Top="{Binding LeftPupilY}" />
                            <Rectangle Width="7"
                                       Height="7"
                                       Fill="#22080D"
                                       Canvas.Left="{Binding RightPupilX}"
                                       Canvas.Top="{Binding RightPupilY}" />
                            <Rectangle Width="2"
                                       Height="2"
                                       Fill="#FFE8C1"
                                       Canvas.Left="{Binding LeftPupilX}"
                                       Canvas.Top="{Binding LeftPupilY}" />
                            <Rectangle Width="2"
                                       Height="2"
                                       Fill="#FFE8C1"
                                       Canvas.Left="{Binding RightPupilX}"
                                       Canvas.Top="{Binding RightPupilY}" />
                        </Canvas>

                        <Image Source="{Binding BlinkLayerPath, Converter={StaticResource AssetPathToImageConverter}}"
                               Canvas.Left="{Binding BlinkX}"
                               Canvas.Top="{Binding BlinkY}"
                               Visibility="{Binding IsBlinkVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                    </Canvas>
                </Viewbox>
            </Grid>
        </Border>
    </Grid>
</Window>
