<Window x:Class="CialloClaw.Shell.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CialloClaw 会话舞台"
        Width="760"
        Height="620"
        MinWidth="700"
        MinHeight="560"
        WindowStartupLocation="Manual"
        Background="#FFFDF7EC">
    <Window.Resources>
        <LinearGradientBrush x:Key="StagePanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFF5E3" Offset="0" />
            <GradientStop Color="#FFFCE6CD" Offset="0.55" />
            <GradientStop Color="#FFF9E0C5" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="VoiceOrbBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFDF0D7" Offset="0" />
            <GradientStop Color="#FFF1C991" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="VoiceOrbButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="110" />
            <Setter Property="Height" Value="110" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="OuterRing"
                                     Fill="{StaticResource VoiceOrbBrush}"
                                     Stroke="#D49C5B"
                                     StrokeThickness="2.2" />
                            <Ellipse x:Name="InnerGlow"
                                     Margin="10"
                                     Fill="#FFFFFAEE"
                                     Opacity="0.55" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterRing" Property="Fill" Value="#FFFFE2B9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="OuterRing" Property="Fill" Value="#FFF0C27F" />
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                <Setter TargetName="OuterRing" Property="Fill" Value="#FFF4B9BD" />
                                <Setter TargetName="OuterRing" Property="Stroke" Value="#C84C5C" />
                                <Setter TargetName="InnerGlow" Property="Fill" Value="#FFFFF1F2" />
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OuterRing" Property="Fill" Value="#FFE7D7B8" />
                                <Setter TargetName="OuterRing" Property="Stroke" Value="#C8B79B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Padding="14" Background="#FFFDF6E8" BorderBrush="#E7C47A" BorderThickness="1.4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="灵闻舞台" FontSize="22" FontWeight="Bold" Foreground="#8E1E2C" />
                    <TextBlock Text="不堆叠传统聊天气泡，而是围绕当前意图展开这一轮对话。"
                               Foreground="#8A6A47"
                               Margin="0,2,0,0" />
                    <TextBlock Text="{Binding StatusText, StringFormat=当前状态：{0}}"
                               Foreground="#73563A"
                               Margin="0,5,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="助手："
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               Foreground="#6A4E2A" />
                    <ComboBox Width="132"
                              Margin="0,0,8,0"
                              ItemsSource="{Binding Agents}"
                              DisplayMemberPath="DisplayName"
                              SelectedItem="{Binding SelectedAgent}" />
                    <Button Content="清空轨道" Width="82" Command="{Binding ClearCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Background="#FFFFF9EF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="回声轨道" FontSize="17" FontWeight="Bold" Foreground="#8E1E2C" />
                        <TextBlock Text="{Binding EchoTrailHeader}" Foreground="#8B7352" Margin="0,2,0,0" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EchoTrail}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="10"
                                            CornerRadius="12"
                                            BorderBrush="#E5BE7A"
                                            BorderThickness="1.1"
                                            Background="{Binding Role, Converter={StaticResource RoleToBackgroundConverter}}">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Text="{Binding DisplayRoleLabel}" FontWeight="Bold" Foreground="#7C2732" />
                                                <TextBlock Text="{Binding DisplayTime}" DockPanel.Dock="Right" FontSize="10" Foreground="#7B6A54" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding PreviewText}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding DurationText}" Margin="0,4,0,0" FontSize="10" Foreground="#8B7352">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DurationText}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource CardBorderStyle}"
                        Background="{StaticResource StagePanelBrush}"
                        BorderBrush="#E6BC72"
                        BorderThickness="1.6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="{Binding FeaturedTitle}" FontSize="20" FontWeight="Bold" Foreground="#8E1E2C" />
                                <TextBlock Text="把当前对话压缩成一张主舞台卡，而不是不断堆聊天记录。"
                                           Foreground="#8A6A47"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                            <Border DockPanel.Dock="Right"
                                    Padding="10,4"
                                    CornerRadius="10"
                                    Background="#FFFCECD0"
                                    BorderBrush="#E0BA75"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding FeaturedRoleLabel}" FontWeight="Bold" Foreground="#7C2732" />
                            </Border>
                        </DockPanel>

                        <ScrollViewer Grid.Row="1" Margin="0,16,0,12" VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding FeaturedContent}"
                                       TextWrapping="Wrap"
                                       FontSize="22"
                                       LineHeight="34"
                                       Foreground="#412D1D" />
                        </ScrollViewer>

                        <DockPanel Grid.Row="2">
                            <TextBlock Text="{Binding FeaturedMeta}" Foreground="#8B7352" />
                            <Button DockPanel.Dock="Right"
                                    Width="90"
                                    Content="朗读回应"
                                    Command="{Binding SpeakLatestCommand}" />
                        </DockPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,12,0,0"
                        Style="{StaticResource CardBorderStyle}"
                        Background="#FFFFFAF2"
                        BorderBrush="#E5BE7A">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="咒语纸签" FontSize="16" FontWeight="Bold" Foreground="#8E1E2C" />
                                <TextBlock Text="{Binding ComposerStateText}" Foreground="#8B7352" Margin="0,2,0,0" />
                            </StackPanel>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding VoiceDraftText, StringFormat=最近语音：{0}}"
                                       Width="220"
                                       TextWrapping="Wrap"
                                       TextAlignment="Right"
                                       Foreground="#8A6A47">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding VoiceDraftText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <TextBox x:Name="InputBox"
                                     MinHeight="74"
                                     MaxHeight="120"
                                     Padding="12,10"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     KeyDown="InputBox_OnKeyDown" />
                            <TextBlock Margin="14,12,90,0"
                                       VerticalAlignment="Top"
                                       Foreground="#A69278"
                                       Text="写一句意图，比如：帮我把今天的工作安排整理成 3 个优先级。"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InputText}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <DockPanel Grid.Row="2" Margin="0,12,0,0">
                            <WrapPanel DockPanel.Dock="Left">
                                <Button Style="{StaticResource ChipButtonStyle}" Content="总结" Tag="请帮我总结当前内容" Click="QuickChip_OnClick" />
                                <Button Style="{StaticResource ChipButtonStyle}" Content="翻译" Tag="请帮我翻译选中内容" Click="QuickChip_OnClick" />
                                <Button Style="{StaticResource ChipButtonStyle}" Content="解释" Tag="请解释这段内容" Click="QuickChip_OnClick" />
                            </WrapPanel>
                            <Button DockPanel.Dock="Right"
                                    Width="96"
                                    Height="38"
                                    Content="发起本轮"
                                    IsEnabled="{Binding IsSendEnabled}"
                                    Command="{Binding SendCommand}" />
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFF8EC" BorderBrush="#E7C47A">
                    <StackPanel>
                        <TextBlock Text="语音圆盘" FontSize="17" FontWeight="Bold" Foreground="#8E1E2C" />
                        <TextBlock Text="{Binding VoiceStatusText}" Margin="0,3,0,10" Foreground="#8A6A47" TextWrapping="Wrap" />

                        <Button Style="{StaticResource VoiceOrbButtonStyle}"
                                HorizontalAlignment="Center"
                                Tag="{Binding IsListening}"
                                Command="{Binding ToggleVoiceCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding VoiceOrbText}"
                                           HorizontalAlignment="Center"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#7B2333" />
                                <TextBlock Text="语音"
                                           HorizontalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#7A5B3B" />
                            </StackPanel>
                        </Button>

                        <TextBlock Text="{Binding VoiceOrbHint}" Margin="0,10,0,0" TextAlignment="Center" Foreground="#7A5B3B" TextWrapping="Wrap" />

                        <WrapPanel Margin="0,12,0,0">
                            <CheckBox Content="识别后自动发送" IsChecked="{Binding VoiceAutoSendEnabled}" />
                            <CheckBox Content="助手自动朗读" Margin="0,6,0,0" IsChecked="{Binding AutoSpeakEnabled}" />
                        </WrapPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Width="86" Content="朗读当前" Command="{Binding SpeakLatestCommand}" />
                            <Button Width="86" Margin="8,0,0,0" Content="停止朗读" Command="{Binding StopSpeakingCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,12,0,12"
                        Style="{StaticResource CardBorderStyle}"
                        Background="#FFFFFBF4">
                    <StackPanel>
                        <TextBlock Text="灵感动作扇区" FontSize="16" FontWeight="Bold" Foreground="#8E1E2C" />
                        <TextBlock Text="这里不堆聊天气泡，而是先决定这一轮要做什么。"
                                   Margin="0,3,0,10"
                                   Foreground="#8A6A47"
                                   TextWrapping="Wrap" />

                        <Button Margin="0,0,0,8" Content="总结这段内容" Tag="请帮我总结当前内容" Click="QuickChip_OnClick" />
                        <Button Margin="0,0,0,8" Content="把它翻译成中文" Tag="请帮我翻译成中文并保留原意" Click="QuickChip_OnClick" />
                        <Button Margin="0,0,0,8" Content="讲明白这件事" Tag="请用简单直白的方式解释这件事" Click="QuickChip_OnClick" />
                        <Button Margin="0,0,0,8" Content="整理成待办" Tag="请把这件事整理成可执行待办" Click="QuickChip_OnClick" />
                        <Button Content="告诉我下一步" Tag="请给出当前场景最合理的下一步" Click="QuickChip_OnClick" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Background="#FFFDF6E8">
                    <StackPanel>
                        <TextBlock Text="使用方式" FontWeight="Bold" Foreground="#8E1E2C" />
                        <TextBlock Text="1. 点“开麦”直接说。2. 或在纸签里写一句意图。3. 中央舞台只呈现本轮最重要的内容。"
                                   Margin="0,6,0,0"
                                   Foreground="#7A5B3B"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
