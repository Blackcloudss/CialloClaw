<Application x:Class="CialloClaw.Shell.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:CialloClaw.Shell.Infrastructure">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <infra:RoleToAlignmentConverter x:Key="RoleToAlignmentConverter" />
        <infra:RoleToBackgroundConverter x:Key="RoleToBackgroundConverter" />
        <infra:AssetPathToImageConverter x:Key="AssetPathToImageConverter" />

        <SolidColorBrush x:Key="AppBgBrush" Color="#FFFDF8EE" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E8C989" />
        <SolidColorBrush x:Key="CardBgBrush" Color="#FFFFFCF4" />
        <SolidColorBrush x:Key="AccentBrush" Color="#9A1E34" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#F8E9CE" />

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI,Microsoft JhengHei UI" />
            <Setter Property="Background" Value="{StaticResource AppBgBrush}" />
            <Setter Property="Foreground" Value="#3A2E24" />
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderBrush" Value="#E0B76D" />
            <Setter Property="Background" Value="#FFF6E9CB" />
            <Setter Property="Foreground" Value="#7B2A2A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFFFF1D8" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFF1D8AC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="#FFFFF7E6" />
            <Setter Property="BorderBrush" Value="#E5BF7D" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="Foreground" Value="#5B3328" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFAEE" />
            <Setter Property="BorderBrush" Value="#E5BF7D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#4B372C" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#5E3A2C" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8E1E2C" />
        </Style>

        <Style x:Key="ChipButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="BorderBrush" Value="#D8A95C" />
            <Setter Property="Background" Value="#FFFCEAC8" />
            <Setter Property="Foreground" Value="#7B2A2A" />
        </Style>
    </Application.Resources>
</Application>
